# ─────────────────────────────────────────────────────────────
# Open Door Bakery — environment variables
# Copy to .env.local and fill in. The app degrades gracefully when
# a service's keys are absent (logs the intended action instead).
# ─────────────────────────────────────────────────────────────

# Neon Postgres (required for anything DB-backed)
DATABASE_URL="postgres://user:password@ep-xxxx.eu-west-2.aws.neon.tech/neondb?sslmode=require"

# Admin dashboard — single owner password + session signing secret
ADMIN_PASSWORD="change-me"
SESSION_SECRET="generate-a-long-random-string"

# Public site URL (used for Stripe redirects + Reply-To addresses)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Stripe (hosted Checkout + refunds)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Resend (transactional email)
RESEND_API_KEY="re_..."
EMAIL_FROM="Open Door Bakery <orders@thepastrybox.co.uk>"
EMAIL_REPLY_DOMAIN="thepastrybox.co.uk"   # used for order+ORD-0084@domain Reply-To
OWNER_EMAIL="hello@thepastrybox.co.uk"    # contact-form + enquiry intake recipient

# Twilio (SMS)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_FROM_NUMBER="+441234567890"
OWNER_SMS_NUMBER="+447000000000"          # owner new-order alerts

# Cloudinary (product images)
CLOUDINARY_CLOUD_NAME="..."
CLOUDINARY_API_KEY="..."
CLOUDINARY_API_SECRET="..."

# Clerk — owner login for the dashboard. When these are set, /dashboard and
# /api/admin are gated by Clerk sign-in (the ADMIN_PASSWORD login is retired)
# and only ADMIN_ALLOWED_EMAILS may enter. Leave blank to use ADMIN_PASSWORD.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
ADMIN_ALLOWED_EMAILS="owner@example.com"   # comma-separated allowlist
